      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Authentication",
            "pages": ["api/auth/login", "api/auth/verify"]
          },
          {
            "group": "Resources",
            "pages": ["api/usuarios", "api/perfiles", "api/modulos", "api/permisos-perfil", "api/menus"]
          }
        ]
      }
    ]
  },
  "keyFeatures": [
    "JWT-based authentication with 24-hour token expiry",
    "Google reCAPTCHA v2 integration on login",
    "Role-based access control with granular per-module permissions (add, edit, view, delete, detail)",
    "Profile management with administrator flag",
    "User management with photo upload support",
    "Menu and module hierarchy system",
    "PostgreSQL database with Exposed ORM and HikariCP connection pool",
    "Bcrypt password hashing",
    "Docker support with fat JAR packaging",
    "Paginated list endpoints for all resources"
  ],
  "publicApiSurface": [
    "POST /api/auth/login",
    "GET /api/auth/verify",
    "GET /api/usuarios",
    "GET /api/usuarios/{id}",
    "POST /api/usuarios",
    "PUT /api/usuarios/{id}",
    "DELETE /api/usuarios/{id}",
    "POST /api/usuarios/{id}/foto",
    "GET /api/perfiles",
