{
  "projectType": "saas",
  "projectName": "Seguridad App",
  "projectDescription": "A Ktor-based security management API that handles user authentication, role-based access control, profile management, and module-level permissions with JWT and reCAPTCHA support.",
  "theme": "luma",
  "primaryColor": "#c03fd3",
  "lightColor": "#c71a69",
  "darkColor": "#252c2d",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "deployment"]
          },
          {
            "group": "Core Concepts",
            "pages": ["concepts/authentication", "concepts/roles-permissions", "concepts/menus-modules"]
          },
          {
            "group": "Configuration",
